{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Designer Extension in Dev Mode",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/apps/vs-code-designer/dist"],
      "trace": false,
      "internalConsoleOptions": "openOnFirstSessionStart",
      "outFiles": ["${workspaceFolder}/apps/vs-code-designer/dist/*.js"],
      "preLaunchTask": "npm: build:extension",
      "env": {
        "DEBUGTELEMETRY": "v"
      }
    },
    {
      "name": "Chat Tests (Extension Host)",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/apps/vs-code-designer/dist",
        "--extensionTestsPath=${workspaceFolder}/apps/vs-code-designer/out/test/e2e/runChatTests",
        "${workspaceFolder}/apps/vs-code-designer/e2e/test-workspace/test-workspace.code-workspace"
      ],
      "outFiles": [
        "${workspaceFolder}/apps/vs-code-designer/out/test/e2e/**/*.js",
        "${workspaceFolder}/apps/vs-code-designer/dist/**/*.js"
      ]
    }
  ]
}
